# Consultar itens no carrinho do usuįrio
GET {{url}}
Authorization: {{token}}
Accept: application/json
###

# Consultar apenas um item do carrinho do usuįrio
GET {{url}}/11
Authorization: {{token}}
Accept: application/json

###

# Adicionar um novo item no carrinho
POST {{url}}
Authorization: {{token}}
Content-Type: application/json
Accept: application/json

{
  "jogoId": 3,
  "quantidade": 1
}

###

# Atualizar a quantidade de um item do carrinho
PATCH {{url}}/11
Authorization: {{token}}
Content-Type: application/json
Accept: application/json

{
  "quantidade": 3
}

###

# Remover um item do carrinho
DELETE {{url}}/7
Authorization: {{token}}
Content-Type: application/json
Accept: application/json
